<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 边框颜色和宽度 -->
    <stroke
        android:width="2dp"
        android:color="@color/black" />

    <!-- 背景颜色 -->
    <solid android:color="#9DE7E3E3" />

    <!-- 圆角 -->
    <corners android:radius="8dp" />

    <!-- 内边距 -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>